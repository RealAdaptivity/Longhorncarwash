{
  "expo": {
    "name": "Longhorn Car Wash",
    "slug": "longhorn-carwash",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.longhorncarwash.timeclock",
      "appleTeamId": "68QFVQ738K",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.longhorncarwash.timeclock",
      "adaptiveIcon": {
        "backgroundColor": "#0f1117"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Longhorn Car Wash needs your location to verify you are on-site when clocking in."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0f1117"
        }
      ],
      "expo-secure-store",
      "expo-status-bar",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0f1117"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "5738d76c-665f-4844-8a99-cd5d37822abd"
      }
    },
    "owner": "versareal"
  }
}
